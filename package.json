  "description": "",
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "allure-commandline": "^2.38.0",
    "cypress": "^14.5.4"
  }
}
